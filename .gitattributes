# Fix C++ detection in Flutter projects
windows/** linguist-detectable=false
linux/** linguist-detectable=false
macos/** linguist-detectable=false

# Ignore generated C++ and other platform files
*.cpp linguist-detectable=false
*.h linguist-detectable=false
*.cc linguist-detectable=false
*.cmake linguist-detectable=false
*.gradle linguist-detectable=false
*.plist linguist-detectable=false
